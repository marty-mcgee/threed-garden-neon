    "db:generate:threed": "drizzle-kit generate --config=./drizzle.threed.config.ts",
    "db:migrate:threed": "drizzle-kit migrate --config=./drizzle.threed.config.ts",
    "db:studio:threed": "drizzle-kit studio --config=./drizzle.threed.config.ts"
  },
